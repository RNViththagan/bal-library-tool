# Copy this file to .env and set one of the options below.

# Option A: point directly to the JAR file
# LS_EXTENSION_JAR=/path/to/flow-model-generator-ls-extension-1.7.0.alpha4.jar

# Option B: point to a local ballerina-language-server checkout
# (the script derives the JAR path from this)
# LS_BUILD=/path/to/ballerina-language-server
